&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;final&lt;/span&gt; count &lt;span style="color:#f92672"&gt;=&lt;/span&gt; data[&lt;span style="color:#e6db74"&gt;&amp;#39;count&amp;#39;&lt;/span&gt;] &lt;span style="color:#f92672"&gt;as&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;int&lt;/span&gt;; &lt;span style="color:#75715e"&gt;// String cannot be cast to int
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#75715e"&gt;// Fix: parse correctly
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;final&lt;/span&gt; count &lt;span style="color:#f92672"&gt;=&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;int&lt;/span&gt;.parse(data[&lt;span style="color:#e6db74"&gt;&amp;#39;count&amp;#39;&lt;/span&gt;] &lt;span style="color:#f92672"&gt;as&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;String&lt;/span&gt;);
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#75715e"&gt;// Or handle both types
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;final&lt;/span&gt; count &lt;span style="color:#f92672"&gt;=&lt;/span&gt; (data[&lt;span style="color:#e6db74"&gt;&amp;#39;count&amp;#39;&lt;/span&gt;] &lt;span style="color:#f92672"&gt;as&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;num&lt;/span&gt;&lt;span style="color:#f92672"&gt;?&lt;/span&gt;)&lt;span style="color:#f92672"&gt;?&lt;/span&gt;.toInt() &lt;span style="color:#f92672"&gt;??&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;0&lt;/span&gt;;
