&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;install.packages&lt;/span&gt;(&lt;span style="color:#e6db74"&gt;&amp;#34;devtools&amp;#34;&lt;/span&gt;)
