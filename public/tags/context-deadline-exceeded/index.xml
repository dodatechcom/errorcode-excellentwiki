&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;defer&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;cancel&lt;/span&gt;()
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;fetchUser&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;ctx&lt;/span&gt;) &lt;span style="color:#75715e"&gt;// May take 1s&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;fetchOrders&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;ctx&lt;/span&gt;) &lt;span style="color:#75715e"&gt;// May take 5s&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;fetchReviews&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;ctx&lt;/span&gt;) &lt;span style="color:#75715e"&gt;// May take 5s — total 11s &amp;gt; 10s&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#75715e"&gt;// Correct — per-operation timeouts&lt;/span&gt;
