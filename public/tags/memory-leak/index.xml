&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#a6e22e"&gt;fetchUser&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;userId&lt;/span&gt;).&lt;span style="color:#a6e22e"&gt;then&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;res&lt;/span&gt; =&amp;gt; &lt;span style="color:#a6e22e"&gt;setData&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;res&lt;/span&gt;)); &lt;span style="color:#75715e"&gt;// Warning if unmounted
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; }, [&lt;span style="color:#a6e22e"&gt;userId&lt;/span&gt;]);
