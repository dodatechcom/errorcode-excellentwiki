&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;return&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;data&lt;/span&gt; &lt;span style="color:#f92672"&gt;?&lt;/span&gt; &amp;lt;&lt;span style="color:#f92672"&gt;Text&lt;/span&gt;&amp;gt;{&lt;span style="color:#a6e22e"&gt;data&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;name&lt;/span&gt;}&amp;lt;/&lt;span style="color:#f92672"&gt;Text&lt;/span&gt;&amp;gt; &lt;span style="color:#f92672"&gt;:&lt;/span&gt; &amp;lt;&lt;span style="color:#f92672"&gt;ActivityIndicator&lt;/span&gt; /&amp;gt;;
