&lt;li&gt;&lt;a href="https://errorcode.excellentwiki.com/languages/php/headers-sent/"&gt;PHP Cannot modify header information&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="https://errorcode.excellentwiki.com/languages/php/warning-count/"&gt;PHP Warning: count()&lt;/a&gt;&lt;/li&gt;
