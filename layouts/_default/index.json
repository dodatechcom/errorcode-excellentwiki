{{- $pages := where .Site.RegularPages "Section" "!=" "" -}}
{{- $items := slice -}}
{{- range $pages -}}
  {{- $item := dict "title" .Title "description" .Description "url" .Permalink "section" .Section "weight" .Weight -}}
  {{- if .Params.error_code }}{{ $item = merge $item (dict "error_code" .Params.error_code) }}{{ end -}}
  {{- if .Params.platforms }}{{ $item = merge $item (dict "platforms" .Params.platforms) }}{{ end -}}
  {{- if .Params.languages }}{{ $item = merge $item (dict "languages" .Params.languages) }}{{ end -}}
  {{- if .Params.error_types }}{{ $item = merge $item (dict "error_types" .Params.error_types) }}{{ end -}}
  {{- if .Params.severities }}{{ $item = merge $item (dict "severities" .Params.severities) }}{{ end -}}
  {{- if .Params.tags }}{{ $item = merge $item (dict "tags" .Params.tags) }}{{ end -}}
  {{- if .Params.deprecated_function }}{{ $item = merge $item (dict "deprecated_function" .Params.deprecated_function "replacement_function" .Params.replacement_function) }}{{ end -}}
  {{- $items = $items | append $item -}}
{{- end -}}
{{- dict "total" (len $items) "errors" $items | jsonify -}}
